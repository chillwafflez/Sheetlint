# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Application environment: local | staging | production | test
ENVIRONMENT=local

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS — JSON-encoded list of allowed origins (frontend URLs)
CORS_ORIGINS=["http://localhost:3000"]

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Job result retention
JOB_RESULT_TTL_HOURS=24
JOB_CLEANUP_INTERVAL_SECONDS=600

# Anthropic / AI semantic checks. Leave blank to disable the AI detector.
ANTHROPIC_API_KEY=

# Set to false to skip the AI detector even when the key is set
ENABLE_AI=true
